{
  "name": "upstage-cli",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "bin": {
    "upstage": "src/cli/index.mjs"
  },
  "scripts": {
    "dev": "node src/cli/index.mjs",
    "start": "node src/cli/index.mjs",
    "check": "node --check src/cli/index.mjs",
    "test": "node --test",
    "lint": "eslint src/ tests/ scripts/",
    "smoke": "node scripts/smoke.mjs",
    "ci": "npm run check && npm run lint && npm test && npm run smoke",
    "go:tui": "go run ./cmd/upstage-tui"
  },
  "dependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "chalk": "^4.1.2",
    "ink": "^6.8.0",
    "ink-divider": "^4.1.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0"
  }
}
